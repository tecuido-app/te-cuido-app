# =============================================================
# TE CUIDO — variables de entorno
# Copiar este archivo a .env y completar con valores reales.
# =============================================================

# === Gemini (AI filter) ===
# Obtener en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === Telegram ===
# Crear bot con @BotFather → obtener token
# Chat ID: mandar /start al bot y llamar /getUpdates (ver README)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_CONTACT_1=
TELEGRAM_CHAT_ID_CONTACT_2=

# === Solana ===
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=                         # Program ID del deploy en Solana Playground
USE_MOCK_SOLANA=false               # true = no escribe on-chain (útil para dev)

# === MQTT (deshabilitado por defecto) ===
USE_MQTT=false
MQTT_BROKER=broker.hivemq.com
MQTT_TOPIC_VITALS=tecuido/carmen/vitals

# === Paciente ===
PATIENT_NAME=Carmen García
PATIENT_AGE=78

# === Dashboard (Next.js) ===
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
NEXT_PUBLIC_PROGRAM_ID=             # igual que PROGRAM_ID
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
