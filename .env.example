# =============================================================
# TE CUIDO — environment variables
# Copy this file to .env and fill in real values.
# =============================================================

# === Gemini (AI filter) ===
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === Telegram ===
# Create a bot with @BotFather to get the token.
# Chat ID: have the contact send /start to the bot, then call /getUpdates (see README).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_CONTACT_1=
TELEGRAM_CHAT_ID_CONTACT_2=

# === Solana ===
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=                         # Program ID from your Solana Playground deploy
USE_MOCK_SOLANA=true                # false = real on-chain writes (requires PROGRAM_ID + idl.json)

# === MQTT (disabled by default) ===
USE_MQTT=false
MQTT_BROKER=broker.hivemq.com
MQTT_TOPIC_VITALS=tecuido/carmen/vitals

# === Patient ===
PATIENT_NAME=Carmen Garcia
PATIENT_AGE=78

# === Dashboard (Next.js) ===
# Local dev / Docker Compose: http://localhost:8000
# Online (Railway agent): https://your-agent.up.railway.app
# Docker Compose overrides this to http://agent:8000 automatically.
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
NEXT_PUBLIC_PROGRAM_ID=             # Same as PROGRAM_ID
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
